# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# On Render, set these in the service's Environment tab instead.

# --- LLM (Groq) --- required for the pipeline (P3+). Get a free key at console.groq.com
GROQ_API_KEY=gsk_your_primary_key_here
GROQ_API_KEY_FALLBACK=gsk_your_fallback_key_here   # optional; used on rate-limit/5xx
GROQ_MODEL_SMALL=llama-3.1-8b-instant
GROQ_MODEL_LARGE=llama-3.3-70b-versatile

# --- Auth --- generate with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=7
ALLOW_OPEN_REGISTRATION=true

# --- Database --- local dev defaults to SQLite; Render injects DATABASE_URL (Postgres)
DATABASE_URL=sqlite:///./solace_dev.db

# --- PubMed / NCBI E-utilities --- no key required; email is NCBI etiquette
NCBI_EMAIL=you@example.com
# NCBI_API_KEY=   # optional, only raises the rate limit

# --- CORS --- '*' is fine for a single-service capstone deploy
CORS_ORIGINS=*
PUBMED_RETMAX=20
